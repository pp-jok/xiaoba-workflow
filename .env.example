# Xiaoba Workflow local environment example.
# Copy to .env for local use if desired. Do not commit .env.

# Lingzao defaults to mock. Set to real only when a local runner and credentials are configured.
XIAOBA_LINGZAO_PROVIDER=mock
XIAOBA_LINGZAO_COMMAND=
XIAOBA_LINGZAO_TIMEOUT=300
LINGZAO_CLIENT_PATH=
LINGZAO_SKILL_ROOT=
LINGZAO_API_KEY=
LINGZAO_BASE_URL=

# Personal Content defaults to mock. Real mode supports mechanism intake,
# governance rule proposal/confirmation, and GenerationContext active-rule lookup.
XIAOBA_PERSONAL_CONTENT_PROVIDER=mock
XIAOBA_PERSONAL_CONTENT_COMMAND=
XIAOBA_PERSONAL_CONTENT_WORKSPACE=

# Hot Learning defaults to mock runner. external requires a user-provided command.
XIAOBA_HOT_LEARNING_PROVIDER=mock
XIAOBA_HOT_LEARNING_COMMAND=
XIAOBA_HOT_LEARNING_MODEL=

# Generation defaults to deterministic mock. external requires a user-provided command.
XIAOBA_GENERATION_PROVIDER=mock
XIAOBA_GENERATION_COMMAND=
XIAOBA_GENERATION_TIMEOUT=300

# Optional when running a local Skill package as a Python module.
PYTHONPATH=
